direction: down

session_start: SessionStart Hook {
  style: {fill: "#e8f5e9"; stroke: "#2e7d32"; border-radius: 10; shadow: true; bold: true}
}
infra: Run infrastructure checks {
  style: {fill: "#ffffff"; stroke: "#4caf50"; border-radius: 8}
}
gen: Generate Tier 1 + Tier 2 files {
  style: {fill: "#ffffff"; stroke: "#4caf50"; border-radius: 8}
}
manifest: Write manifest + sentinel {
  style: {fill: "#ffffff"; stroke: "#4caf50"; border-radius: 8}
}

prompt: UserPromptSubmit Hook {
  style: {fill: "#fff3e0"; stroke: "#ef6c00"; border-radius: 10; shadow: true; bold: true}
}
tier1_check: Tier 1 all read? {
  shape: diamond
  style: {fill: "#fff3e0"; stroke: "#ef6c00"}
}
list_remaining: List remaining files {
  style: {fill: "#ffccbc"; stroke: "#e65100"; border-radius: 8}
}
unblock: Unblock tools {
  style: {fill: "#c8e6c9"; stroke: "#2e7d32"; border-radius: 8}
}

cross: Cross-check runs once {
  style: {fill: "#e3f2fd"; stroke: "#1565c0"; border-radius: 8}
}

pretool: PreToolUse Hook {
  style: {fill: "#e3f2fd"; stroke: "#1565c0"; border-radius: 10; shadow: true; bold: true}
}
t2_keyword: Tier 2 keyword? {
  shape: diamond
  style: {fill: "#e3f2fd"; stroke: "#1565c0"}
}
load_ctx: Load additional context {
  style: {fill: "#bbdefb"; stroke: "#1565c0"; border-radius: 8}
}
execute: Tool executes {
  style: {fill: "#ffffff"; stroke: "#1565c0"; border-radius: 8}
}

posttool: PostToolUse Hook {
  style: {fill: "#e3f2fd"; stroke: "#1565c0"; border-radius: 10; shadow: true; bold: true}
}
rz_scan: Rule Zero scan {
  style: {fill: "#ffffff"; stroke: "#2196f3"; border-radius: 8}
}
edit_count: Edit count + save reminder {
  style: {fill: "#ffffff"; stroke: "#2196f3"; border-radius: 8}
}

stop_hook: Stop Hook {
  style: {fill: "#fce4ec"; stroke: "#c62828"; border-radius: 10; shadow: true; bold: true}
}
sv_check: Fixes re-checked? {
  shape: diamond
  style: {fill: "#fce4ec"; stroke: "#c62828"}
}
retry: Exit code 2 — retry {
  style: {fill: "#ffcdd2"; stroke: "#c62828"; border-radius: 8}
}
fix: Agent fixes issue {
  style: {fill: "#ffcdd2"; stroke: "#c62828"; border-radius: 8}
}
clean_check: Repos clean? Audit passes? {
  shape: diamond
  style: {fill: "#fce4ec"; stroke: "#c62828"}
}
exit: Session ends {
  style: {fill: "#c8e6c9"; stroke: "#2e7d32"; border-radius: 8; bold: true}
}

session_start -> infra
infra -> gen
gen -> manifest
manifest -> prompt

prompt -> tier1_check
tier1_check -> list_remaining: NO {style: {stroke: "#e65100"}}
tier1_check -> unblock: YES {style: {stroke: "#2e7d32"}}
unblock -> cross

cross -> pretool
pretool -> t2_keyword
t2_keyword -> load_ctx: match {style: {stroke: "#1565c0"}}
t2_keyword -> execute: allowed
load_ctx -> execute
execute -> posttool

posttool -> rz_scan
posttool -> edit_count

execute -> stop_hook: session ending {style: {stroke: "#c62828"; stroke-dash: 5}}

stop_hook -> sv_check
sv_check -> retry: NO {style: {stroke: "#c62828"}}
retry -> fix
fix -> stop_hook
sv_check -> clean_check: YES
clean_check -> retry: NO {style: {stroke: "#c62828"}}
clean_check -> exit: YES {style: {stroke: "#2e7d32"; stroke-width: 3}}
